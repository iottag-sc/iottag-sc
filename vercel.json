{
  "redirects": [
    {
      "source": "/platform/environmental-monitoring/:path*",
      "destination": "/platform/environmental-intelligence/:path*",
      "permanent": true
    },
    {
      "source": "/technology/vector-tag/:path*",
      "destination": "/technology/engineering-hardware/",
      "permanent": true
    }
  ],
  "headers": [
    {
      "source": "/assets/img/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/assets/icon/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/assets/(css|js)/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=86400" }
      ]
    }
  ]
}
